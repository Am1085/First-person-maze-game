[sub_resource type="GDScript" id="GDScript_g4xdh"]
script/source = "extends Area3D

var game_finished = false

func _ready():
	monitoring = true
	monitorable = true
	body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	if body.name != \"Player\":
		return
	if game_finished:
		return
		
	game_finished = true
	print(\"PLAYER REACHED GOAL\")

	# Step 1 - stop timer
	var scene = get_tree().current_scene
	if scene.has_method(\"get\") and \"timer_running\" in scene:
		scene.timer_running = false
	print(\"timer stopped\")

	# Step 2 - stop footsteps
	var footsteps = body.get_node_or_null(\"Footsteps\")
	if footsteps:
		footsteps.stop()
		footsteps.volume_db = -80.0
	print(\"footsteps stopped\")

	# Step 3 - stop player
	body.velocity = Vector3.ZERO
	if \"game_over\" in body:
		body.game_over = true
	print(\"player stopped\")

	# Step 4 - free mouse
	Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
	print(\"mouse freed\")

	# Step 5 - show win screen
	var win_screen = scene.get_node_or_null(\"UI/WinScreen\")
	print(\"WinScreen: \", win_screen)
	if win_screen and win_screen.has_method(\"show_win\"):
		var time = 0.0
		if \"time_elapsed\" in scene:
			time = scene.time_elapsed
		print(\"calling show_win with time: \", time)
		win_screen.show_win(time)
	else:
		print(\"ERROR: show_win method not found on WinScreen\")

	# Step 6 - disable physics deferred
	body.call_deferred(\"set_physics_process\", false)
	body.call_deferred(\"set_process\", false)

func _input(event):
	if event.is_action_pressed(\"ui_accept\"):
		get_tree().reload_current_scene()
"

